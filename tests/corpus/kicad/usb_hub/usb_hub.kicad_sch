(kicad_sch (version 20230121) (generator "eeschema")
  (title_block (title "USB Hub Top") (rev "1.0")
    (company "ZapTrace Corpus")
  )
  (symbol (lib_id "Device:capacitor") (at 50 20 0) (unit 1)
    (property "Reference" "C1" (at 50 15 0))
    (property "Value" "100nF" (at 50 25 0))
    (property "Footprint" "Capacitor_SMD:C_0402_1005Metric" (at 50 30 0))
    (pin "P1" (at 40 20 0))
    (pin "P2" (at 60 20 0))
  )
  (symbol (lib_id "Device:resistor") (at 80 20 0) (unit 1)
    (property "Reference" "R1" (at 80 15 0))
    (property "Value" "22R" (at 80 25 0))
    (property "Footprint" "Resistor_SMD:R_0402_1005Metric" (at 80 30 0))
    (pin "P1" (at 70 20 0))
    (pin "P2" (at 90 20 0))
  )
  (wire (pts (xy 30 20) (xy 40 20)))
  (wire (pts (xy 60 20) (xy 70 20)))
  (wire (pts (xy 30 30) (xy 30 20)))
  (label "USB_VBUS" (at 30 20 0))
  (label "HUB_DP" (at 60 20 0))
  (global_label "GND" (shape "output") (at 90 20 0))
  (global_label "VBUS_IN" (shape "input") (at 30 30 0))
  (sheet
    (property "Sheet name" "power_input")
    (property "Sheet file" "usb_hub_sheets/power_input.kicad_sch")
    (pin "VBUS_OUT" (at 80 50 0))
    (pin "GND" (at 80 60 0))
  )
  (sheet
    (property "Sheet name" "data_path")
    (property "Sheet file" "usb_hub_sheets/data_path.kicad_sch")
    (pin "DP_IN" (at 120 50 0))
    (pin "DM_IN" (at 120 60 0))
  )
)
