(kicad_sch (version 20230121) (generator "eeschema")
  (title_block (title "Power Supply Sheet"))
  (symbol (lib_id "Device:capacitor") (at 50 50 0) (unit 1)
    (property "Reference" "C1" (at 50 45 0))
    (property "Value" "100n" (at 50 55 0))
    (pin "P1" (at 45 50 0))
    (pin "P2" (at 55 50 0))
  )
  (symbol (lib_id "Device:regulator") (at 100 50 0) (unit 1)
    (property "Reference" "U1" (at 100 45 0))
    (property "Value" "LDO_3V3" (at 100 55 0))
    (pin "IN" (at 95 50 0))
    (pin "OUT" (at 105 50 0))
    (pin "GND" (at 100 55 0))
  )
  (wire (pts (xy 55 50) (xy 95 50)))
  (label "PWR_IN" (at 45 50 0))
  (hierarchical_label "PWR_OUT" (shape "output") (at 110 50 0))
  (global_label "GND" (shape "output") (at 100 60 0))
)
