(kicad_sch (version 20230121) (generator "eeschema")
  (title_block (title "Multi-Sheet Test") (rev "1.0")
    (company "ZapTrace Test")
  )
  (symbol (lib_id "Device:resistor") (at 50 50 0) (unit 1)
    (property "Reference" "R1" (at 50 45 0))
    (property "Value" "10k" (at 50 55 0))
    (pin "P1" (at 45 50 0))
    (pin "P2" (at 55 50 0))
  )
  (wire (pts (xy 55 50) (xy 65 50)))
  (wire (pts (xy 65 50) (xy 75 50)))
  (label "VCC" (at 45 50 0))
  (global_label "GND" (shape "output") (at 55 50 0))
  (sheet
    (property "Sheet name" "power_supply")
    (property "Sheet file" "power_supply.kicad_sch")
    (pin "PWR_IN" (at 100 50 0))
    (pin "PWR_OUT" (at 100 60 0))
  )
  (sheet
    (property "Sheet name" "signal_path")
    (property "Sheet file" "signal_path.kicad_sch")
    (pin "SIG_IN" (at 150 50 0))
  )
)
