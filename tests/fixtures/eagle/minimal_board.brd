<?xml version="1.0" encoding="utf-8"?>
<!-- Synthetic Eagle board fixture for ZapTrace round-trip tests.
     Format: Eagle XML schema 7.x (Autodesk Eagle 7+).
     License: Synthetic test fixture, no copyright. -->
<eagle version="7.7.0">
  <drawing>
    <settings>
      <setting alwaysvectorfont="no"/>
    </settings>
    <grid distance="0.1" unitdist="mm" unit="mm" style="lines" multiple="1" display="no" altdistance="0.01" altunitdist="mm" altunit="mm"/>
    <layers>
      <layer number="1" name="Top" color="4" fill="1" visible="yes" active="yes"/>
      <layer number="16" name="Bottom" color="1" fill="1" visible="yes" active="yes"/>
      <layer number="17" name="Pads" color="2" fill="1" visible="yes" active="yes"/>
      <layer number="18" name="Vias" color="2" fill="1" visible="yes" active="yes"/>
      <layer number="20" name="Dimension" color="15" fill="1" visible="yes" active="yes"/>
    </layers>
    <board>
      <plain>
        <wire x1="0" y1="0" x2="30" y2="0" width="0.127" layer="20"/>
        <wire x1="30" y1="0" x2="30" y2="20" width="0.127" layer="20"/>
        <wire x1="30" y1="20" x2="0" y2="20" width="0.127" layer="20"/>
        <wire x1="0" y1="20" x2="0" y2="0" width="0.127" layer="20"/>
      </plain>
      <components>
        <component name="R1" library="rcl" deviceset="R-EU_" device="R0402" value="10k"/>
        <component name="R2" library="rcl" deviceset="R-EU_" device="R0402" value="1k"/>
        <component name="C1" library="rcl" deviceset="C-EU_" device="C0402" value="100nF"/>
        <component name="U1" library="ic-package" deviceset="STM32F103C8Tx" device="" value="STM32F103C8T6"/>
      </components>
      <libraries>
        <library name="rcl">
          <packages>
            <package name="R0402">
              <description>Resistor 0402</description>
              <smd name="1" x="-0.5" y="0" dx="0.5" dy="0.5" layer="1"/>
              <smd name="2" x="0.5" y="0" dx="0.5" dy="0.5" layer="1"/>
            </package>
            <package name="C0402">
              <description>Capacitor 0402</description>
              <smd name="1" x="-0.5" y="0" dx="0.5" dy="0.5" layer="1"/>
              <smd name="2" x="0.5" y="0" dx="0.5" dy="0.5" layer="1"/>
            </package>
          </packages>
        </library>
      </libraries>
      <elements>
        <element name="R1" library="rcl" package="R0402" value="10k" x="5" y="5" smashed="no">
          <attribute name="NAME" x="5.3" y="5.3" size="1.27" layer="25"/>
        </element>
        <element name="R2" library="rcl" package="R0402" value="1k" x="10" y="5" smashed="no"/>
        <element name="C1" library="rcl" package="C0402" value="100nF" x="15" y="5" smashed="no"/>
        <element name="U1" library="ic-package" package="LQFP48" value="STM32F103C8T6" x="15" y="12" smashed="no"/>
      </elements>
      <signals>
        <signal name="VCC">
          <contactref element="R1" pad="1"/>
          <contactref element="U1" pad="1"/>
          <wire x1="4.5" y1="5" x2="14.5" y2="12" width="0.2032" layer="1"/>
        </signal>
        <signal name="GND">
          <contactref element="R1" pad="2"/>
          <contactref element="C1" pad="2"/>
          <contactref element="U1" pad="2"/>
          <wire x1="5.5" y1="5" x2="15.5" y2="5" width="0.2032" layer="1"/>
        </signal>
        <signal name="SPI_MOSI">
          <contactref element="R2" pad="1"/>
          <contactref element="U1" pad="3"/>
          <wire x1="9.5" y1="5" x2="14.5" y2="11" width="0.2032" layer="1"/>
        </signal>
      </signals>
      <via x="7.5" y="7.5" extent="1-16" drill="0.4"/>
      <via x="12.5" y="7.5" extent="1-16" drill="0.4"/>
    </board>
  </drawing>
</eagle>
