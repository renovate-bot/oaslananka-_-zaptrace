{
  "$schema": "https://zaptrace.dev/schemas/plugin-manifest-v1.json",
  "api_version": "1.0",
  "plugin_id": "dev.zaptrace.examples.overbroad",
  "name": "Hello Analyzer",
  "version": "0.1.0",
  "min_zaptrace_version": "0.2.0",
  "max_zaptrace_version": "0.3.0",
  "entry": {
    "type": "python_module",
    "path": "hello_analyzer"
  },
  "extension_points": [
    "report_generator"
  ],
  "capabilities": [
    "design:read"
  ],
  "permissions": {
    "filesystem": {
      "read": [],
      "write": [
        "outputs/"
      ]
    },
    "network": {
      "allowed_domains": [
        "*.example.com"
      ],
      "allowed_schemes": [
        "http"
      ]
    },
    "subprocess": true
  },
  "signing": {
    "algorithm": "ed25519",
    "signature": "dev-fixture-signature",
    "public_key_fingerprint": "sha256:dev-fixture"
  },
  "description": "Deterministic no-exec example manifest for CI admission tests.",
  "author": "ZapTrace Core Team"
}
